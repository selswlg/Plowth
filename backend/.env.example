# Database
DATABASE_URL=postgresql+asyncpg://real_user:real_dev_password@localhost:5432/real_db
AUTO_CREATE_TABLES=false

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Auth
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI
GEMINI_API_KEY=your-gemini-api-key-here
AI_MODEL_HIGH=gemini-2.5-pro
AI_MODEL_LOW=gemini-2.0-flash

# S3 Storage (optional for MVP)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=real-uploads

# App
APP_ENV=development
APP_DEBUG=true
APP_NAME=Plowth

# API / Runtime
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080
JOB_EXECUTION_MODE=in_process
